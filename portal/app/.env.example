# ============================================================
# Variables de entorno — Dashboard de Facturación
# ASC Auditores y Consultores Empresarial
# Copiar a .env.local y completar los valores reales
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Claude API
ANTHROPIC_API_KEY=sk-ant-api...

# factura.com — API Key de sandbox/producción (una por entorno)
# La API Key activa se almacena también en billing_empresas_api_keys por RFC emisor
FACTURACOM_API_KEY=tu_api_key_aqui
FACTURACOM_SECRET_KEY=tu_secret_key_aqui

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_WEBHOOK_SECRET=tu_webhook_secret_aleatorio

# N8N
N8N_WEBHOOK_URL=https://tu-n8n.railway.app/webhook/...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# factura.com sandbox
  FACTURACOM_API_KEY=tu_api_key_aqui
